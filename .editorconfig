# EditorConfig - consistent whitespace settings across all editors
# https://editorconfig.org

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# C/C++ source files
[*.{cpp,hpp,h,c}]
indent_size = 4

# CMake files
[CMakeLists.txt]
indent_size = 4

[*.cmake]
indent_size = 4

# Markdown (trailing whitespace can be intentional for line breaks)
[*.md]
trim_trailing_whitespace = false

# YAML config files
[*.{yml,yaml}]
indent_size = 2

# JSON config files
[*.json]
indent_size = 2
